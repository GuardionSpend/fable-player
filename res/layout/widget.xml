<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_widget"
    android:padding="10dp">

    <ImageView
        android:id="@+id/w_cover"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_track_placeholder"
        android:contentDescription="@string/cover"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginLeft="12dp"
        android:layout_marginRight="6dp">

        <TextView
            android:id="@+id/w_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="#F2F2F7"
            android:textSize="14sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/w_artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/nothing_playing"
            android:textColor="#9A9AA8"
            android:textSize="11.5sp"
            android:singleLine="true"
            android:ellipsize="end"/>
    </LinearLayout>

    <ImageButton
        android:id="@+id/w_prev"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@android:color/transparent"
        android:src="@drawable/ic_prev"
        android:scaleType="centerInside"
        android:contentDescription="@string/btn_prev"/>

    <ImageButton
        android:id="@+id/w_play"
        android:layout_width="46dp"
        android:layout_height="46dp"
        android:background="@android:color/transparent"
        android:src="@drawable/ic_play"
        android:scaleType="centerInside"
        android:contentDescription="@string/btn_play"/>

    <ImageButton
        android:id="@+id/w_next"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@android:color/transparent"
        android:src="@drawable/ic_next"
        android:scaleType="centerInside"
        android:contentDescription="@string/btn_next"/>
</LinearLayout>
